<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#FFFFFF"/>

    <!-- Rounded corners -->
    <corners android:radius="18dp"/>

    <!-- Border (light modern outline) -->
    <stroke
        android:width="1dp"
        android:color="@color/primary"/>

    <!-- Padding inside card -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp"/>

</shape>