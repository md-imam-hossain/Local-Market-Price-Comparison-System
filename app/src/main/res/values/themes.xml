<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.LocalMarketPrice" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        
        <!-- Status bar and Toolbar colors -->
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <style name="Theme.LocalMarketPrice" parent="Base.Theme.LocalMarketPrice" />

    <!-- Custom Style for SearchView to force Black Text and Hint -->
    <style name="CustomSearchViewStyle" parent="Widget.AppCompat.SearchView">
        <item name="android:editTextColor">#000000</item>
        <item name="android:textColorHint">#000000</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>